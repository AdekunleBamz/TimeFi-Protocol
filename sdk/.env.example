# TimeFi SDK Environment Configuration
# Copy this file to .env and configure for your environment

# Network Configuration
# Options: mainnet, testnet
NETWORK=mainnet

# Contract Address (deployer address for TimeFi contracts)
CONTRACT_ADDRESS=SP2PABAF9FTAJYNFZH93XENAJ8FVY99RRM50D2JG9

# API Endpoint
# Mainnet: https://api.mainnet.hiro.so
# Testnet: https://api.testnet.hiro.so
API_URL=https://api.mainnet.hiro.so

# Debug Mode
# Set to true to enable verbose logging
DEBUG=false

# Rate Limiting
# Delay between API requests in milliseconds (default: 100)
RATE_LIMIT_DELAY=100